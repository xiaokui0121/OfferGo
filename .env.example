# =============================================================
# OfferGo · 环境变量样例
# 复制本文件为 .env 后填入真实值，本地开发自动读取
# Railway 部署时在 Variables 面板手动添加
# =============================================================

# OpenRouter API Key（必填）
# 申请：https://openrouter.ai → Keys → Create new key
# 用于调用 Claude Sonnet 4.5 做简历优化、JD 抽取、面试复盘
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Node 运行模式（部署平台一般会自动注入 production）
NODE_ENV=development

# 服务端口（Railway 会自动注入 PORT，本地默认 5000）
PORT=5000

# 数据持久化路径（生产环境指向持久磁盘）
# 本地不填默认走项目根目录，Railway 上挂载 /app/data 后填以下值
# DB_PATH=/app/data/data.db
# DATA_DIR=/app/data
